struct Lang {
    name: string
    version: u32
}

fn makeLang(): Lang {
    return Lang {
        name: "Gust",
        version: 1,
    }
}

fn getName(lang: Lang): string {
    return lang.name
}

fn main() {
    let lang = makeLang()

    io.println(getName(lang))
    io.println(makeLang().name)
}
