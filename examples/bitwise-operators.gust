fn main() {
    let mut permissions: u32 = 0
    permissions |= 1
    permissions |= 4
    permissions ^= 1
    permissions <<= 1
    permissions >>= 2
    permissions &= 3

    let bitwiseWorks = 12 & 10 == 8 &&
        8 | 1 == 9 &&
        7 ^ 3 == 4 &&
        3 << 2 == 12 &&
        16 >> 3 == 2

    if permissions == 2 && bitwiseWorks {
        io.println("Bitwise operators work!")
    }
}
